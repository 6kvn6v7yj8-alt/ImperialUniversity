{
  "expo": {
    "name": "ImperialUniversity",
    "slug": "ImperialUniversity",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E40AF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.imperial.university"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1E40AF"
      },
      "package": "com.imperial.university",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.INTERNET"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Imperial University to access your camera."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Imperial University to access your photos."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "fb1a7780-8ee7-44dc-9023-e5e793f8b0f2"
      }
    }
  }
}